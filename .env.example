# FinSolve RAG Pro - Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to git.

# Security
SECRET_KEY=CHANGE_ME_USE_STRONG_RANDOM_KEY_IN_PRODUCTION
TOKEN_EXPIRE_MINUTES=60

# LLM provider
# Supported values: groq, ollama
# Recommendation: use groq for demos/CI/GitHub publishing, ollama for local-only inference.
LLM_PROVIDER=groq
GROQ_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# Optional model overrides
# If left blank, provider-specific defaults are used.
MODEL_SIMPLE=
MODEL_MODERATE=
MODEL_COMPLEX=
HYDE_MODEL=

# Retrieval tuning
HYDE_ENABLED=true
RERANK_ENABLED=true
HYDE_CANDIDATES=8
RERANK_TOP_K=4

# Vector store
CHROMA_DIR=chroma_db

# Database
DUCKDB_PATH=finsolve_audit.db

# Data ingestion
DATA_DIR=resources/data

# Frontend
API_BASE_URL=http://localhost:8000
